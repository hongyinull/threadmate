{
  "manifest_version": 3,
  "name": "Threadmate — Free AI Replies for Threads & X",
  "short_name": "Threadmate",
  "version": "0.6.14",
  "description": "BYOK AI reply assistant for Threads & X — drafts replies you review before posting. Free, open-source, no backend, no tracking.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html",
  "commands": {
    "generate-reply": {
      "suggested_key": { "default": "Ctrl+Shift+Y", "mac": "Command+Shift+Y" },
      "description": "用 AI 草擬回覆"
    }
  },
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://*.threads.net/*",
    "https://*.threads.com/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.threads.net/*",
        "https://*.threads.com/*",
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
